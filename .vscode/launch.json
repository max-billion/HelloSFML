{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run HelloSFML (Debug)",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceRoot}/Build/Debug/HelloSFML",
            "cwd": "${workspaceRoot}",
            "console": "integratedTerminal",
            "preLaunchTask": "${defaultBuildTask}"
        },
        {
   
            "name": "Run HelloSFML (Debug) Linux",
            "type": "cppdbg",
            "MIMode": "gdb",
            "request": "launch",
            "program": "${workspaceRoot}/Build/HelloSFML",
            "cwd": "${workspaceRoot}",
            "preLaunchTask": "${defaultBuildTask}"
        }
    ]
}